{
  "name": "kroger-qualitrics-staffbase-plugin",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "mkdir -p dist && esbuild src/index.jsx --bundle --outfile=dist/index.js --platform=browser --format=esm --loader:.js=jsx --loader:.jsx=jsx",
    "clean": "rm -rf dist",
    "dev": "nodemon --watch src --ext js,jsx --exec \"npm run build\"",
    "preview": "node preview-server.js"
  },
  "devDependencies": {
    "esbuild": "^0.19.0",
    "nodemon": "^3.0.1"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@staffbase/plugins-client-sdk": "^3.1.2",
    "@staffbase/staffbase-plugin-sdk": "^1.3.8"
  }
}
